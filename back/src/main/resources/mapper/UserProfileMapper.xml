<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.project.mapper.UserProfileMapper">

    <resultMap id="UserProfileEntityMap" type="org.example.project.model.UserProfileEntity">
        <id property="userId" column="user_id"/>
        <result property="avatar" column="avatar"/>
        <result property="bio" column="bio"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findByUserId" resultMap="UserProfileEntityMap">
        SELECT user_id, avatar, bio, updated_at
        FROM user_profile
        WHERE user_id = #{userId}
    </select>

    <insert id="insert" parameterType="org.example.project.model.UserProfileEntity">
        INSERT INTO user_profile (user_id, avatar, bio, updated_at)
        VALUES (#{userId}, #{avatar}, #{bio}, #{updatedAt})
    </insert>

    <update id="update" parameterType="org.example.project.model.UserProfileEntity">
        UPDATE user_profile
        SET avatar = #{avatar},
            bio = #{bio},
            updated_at = #{updatedAt}
        WHERE user_id = #{userId}
    </update>

</mapper>

